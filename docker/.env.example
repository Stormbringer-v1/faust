# ──────────────────────────────────────────────────────────────────────
# Faust Docker — Environment Variables
# Copy to .env and edit values before running docker compose.
# ──────────────────────────────────────────────────────────────────────

# Database
POSTGRES_USER=faust
POSTGRES_PASSWORD=CHANGE_ME_PLEASE
POSTGRES_DB=faust

# JWT (generate: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET_KEY=CHANGE_ME_GENERATE_RANDOM_HEX_STRING

# App
DEBUG=true
ENVIRONMENT=development
CORS_ORIGINS=["http://localhost:3000"]

# AI (optional)
DEFAULT_AI_PROVIDER=ollama
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_AI_API_KEY=
