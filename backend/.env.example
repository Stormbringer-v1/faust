# ──────────────────────────────────────────────────────────────────────
# Faust Backend — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit the .env file to version control.
# ──────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────
APP_NAME=Faust
APP_VERSION=0.1.0
DEBUG=true
ENVIRONMENT=development
# API_V1_PREFIX=/api/v1

# ── Database ─────────────────────────────────────────────────────────
POSTGRES_USER=faust
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=faust
# DB_POOL_SIZE=20
# DB_MAX_OVERFLOW=10

# ── Redis ────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ── JWT / Auth ───────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ─────────────────────────────────────────────────────────────
# Comma-separated list or JSON array
CORS_ORIGINS=["http://localhost:3000"]

# ── Scanning ─────────────────────────────────────────────────────────
SCAN_TIMEOUT_SECONDS=3600
MAX_CONCURRENT_SCANS=5
NMAP_BINARY_PATH=/usr/bin/nmap
# NUCLEI_BINARY_PATH=/usr/local/bin/nuclei
# TRIVY_BINARY_PATH=/usr/local/bin/trivy

# ── AI Providers (all optional) ──────────────────────────────────────
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_AI_API_KEY=...
# OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_AI_PROVIDER=ollama

# ── First Admin Seed (optional) ─────────────────────────────────────
# If set, creates admin user on first run
FIRST_ADMIN_EMAIL=admin@faust.local
# FIRST_ADMIN_PASSWORD=
